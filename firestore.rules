rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validation
    function isValidErrorRecord(data) {
      return data.keys().hasAll(['userId', 'originalText', 'knowledgePoint', 'variations', 'createdAt'])
        && data.keys().size() == 5
        && data.userId is string && data.userId.size() <= 128
        && data.originalText is string && data.originalText.size() <= 5000
        && data.knowledgePoint is string && data.knowledgePoint.size() <= 200
        && data.variations is list && data.variations.size() == 3
        && data.createdAt == request.time
        && data.userId == request.auth.uid;
    }

    match /errorRecords/{recordId} {
      allow create: if isSignedIn() 
        && isValidId(recordId) 
        && isValidErrorRecord(incoming());
      
      allow update: if false; // Error records are immutable in this version for simplicity/security
      
      allow delete: if isSignedIn() 
        && isOwner(existing().userId);
      
      allow get: if isSignedIn() 
        && isOwner(existing().userId);
      
      allow list: if isSignedIn() 
        && resource.data.userId == request.auth.uid;
    }
  }
}
